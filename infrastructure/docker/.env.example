# Copie este arquivo para ".env" e ajuste os valores para o seu ambiente local.
# Nunca commite o arquivo ".env" (ver .gitignore) — RNF-030.

# --- auth-service ---
AUTH_DB_NAME=auth_db
AUTH_DB_USER=auth_db_user
AUTH_DB_PASSWORD=change-me-auth
# Chave HMAC para assinatura dos JWT emitidos no login (RNF-026). Minimo 32 caracteres.
AUTH_JWT_SECRET=change-me-please-use-a-random-32-byte-secret

# --- user-service ---
USER_DB_NAME=user_db
USER_DB_USER=user_db_user
USER_DB_PASSWORD=change-me-user

# --- edital-service ---
EDITAL_DB_NAME=edital_db
EDITAL_DB_USER=edital_db_user
EDITAL_DB_PASSWORD=change-me-edital

# --- study-plan-service ---
STUDY_PLAN_DB_NAME=study_plan_db
STUDY_PLAN_DB_USER=study_plan_db_user
STUDY_PLAN_DB_PASSWORD=change-me-study-plan

# --- ai-service ---
AI_DB_NAME=ai_db
AI_DB_USER=ai_db_user
AI_DB_PASSWORD=change-me-ai

# --- notification-service ---
NOTIFICATION_DB_NAME=notification_db
NOTIFICATION_DB_USER=notification_db_user
NOTIFICATION_DB_PASSWORD=change-me-notification

# --- mensageria ---
# Kafka roda em PLAINTEXT sem autenticacao neste estagio (isolado na rede gabaritai-application,
# nao exposto publicamente — ver ADR-0003). SASL/ACLs ficam para quando o projeto for a producao.

# --- api-gateway ---
CORS_ALLOWED_ORIGINS=http://localhost:4200
